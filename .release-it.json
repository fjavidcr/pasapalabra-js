{
  "hooks": {
    "before:init": "git fetch --tags"
  },
  "github": {
    "release": false
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "push": false,
    "tag": false,
    "requireCleanWorkingDir": false,
    "tagName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  }
}
