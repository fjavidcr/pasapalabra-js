---
import Layout from '../layouts/Layout.astro';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<main class="game-container">
		<header>
			<h1>Pasapalabra AI</h1>
			<p>Rosco generado con Google Gemini</p>
		</header>

		<section id="setup-screen" class="screen active">
			<button id="btn-generate" class="primary-btn">Generar Rosco</button>
			<p id="loading-msg" class="hidden">Generando el rosco con IA... esto puede tardar unos segundos.</p>
			<div id="error-msg" class="hidden error"></div>
		</section>

		<section id="game-screen" class="screen hidden">
			<div class="rosco-container" id="rosco-container">
				<!-- Letters will be generated here by JS -->
			</div>

			<div class="game-controls">
				<div id="current-letter-display" class="current-letter">A</div>
				<p id="definition-display" class="definition">Cargando definición...</p>

				<form id="answer-form">
					<input
						type="text"
						id="answer-input"
						placeholder="Escribe tu respuesta..."
						autocomplete="off"
						required
					/>
					<div class="actions">
						<button type="submit" class="submit-btn">Enviar</button>
						<button type="button" id="btn-pasapalabra" class="pasapalabra-btn">Pasapalabra</button>
					</div>
				</form>
			</div>
		</section>

		<section id="results-screen" class="screen hidden">
			<h2>¡Juego Terminado!</h2>
			<div class="stats">
				<p>Acertadas: <span id="stat-correct">0</span></p>
				<p>Falladas: <span id="stat-incorrect">0</span></p>
			</div>
			<button id="btn-restart" class="primary-btn">Volver a Jugar</button>
		</section>
	</main>
</Layout>

<style>
	:root {
		--bg-color: #0f172a;
		--text-color: #f8fafc;
		--primary: #3b82f6;
		--primary-hover: #2563eb;
		--correct: #22c55e;
		--incorrect: #ef4444;
		--circle-bg: #1e293b;
		--circle-border: #3b82f6;
		--rosco-size: 320px;
	}

	body {
		margin: 0;
		font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		display: flex;
		justify-content: center;
		min-height: 100vh;
	}

	.game-container {
		width: 100%;
		max-width: 600px;
		padding: 2rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	header h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
		color: var(--primary);
	}

	.screen {
		display: none;
		width: 100%;
		flex-direction: column;
		align-items: center;
		animation: fadeIn 0.3s ease-in-out;
	}

	.screen.active {
		display: flex;
	}

	.hidden {
		display: none !important;
	}

	.primary-btn, .submit-btn, .pasapalabra-btn {
		padding: 0.75rem 1.5rem;
		font-size: 1.1rem;
		border: none;
		border-radius: 8px;
		cursor: pointer;
		font-weight: bold;
		transition: background-color 0.2s, transform 0.1s;
	}

	.primary-btn, .submit-btn {
		background-color: var(--primary);
		color: white;
	}

	.primary-btn:hover, .submit-btn:hover {
		background-color: var(--primary-hover);
		transform: translateY(-2px);
	}

	.pasapalabra-btn {
		background-color: #475569;
		color: white;
	}

	.pasapalabra-btn:hover {
		background-color: #334155;
		transform: translateY(-2px);
	}

	#loading-msg {
		margin-top: 1rem;
		color: #94a3b8;
		font-style: italic;
	}

	.error {
		color: var(--incorrect);
		margin-top: 1rem;
		padding: 1rem;
		background-color: rgba(239, 68, 68, 0.1);
		border-radius: 8px;
	}

	/* Rosco Styles */
	.rosco-container {
		position: relative;
		width: var(--rosco-size);
		height: var(--rosco-size);
		margin: 2rem auto;
		border-radius: 50%;
	}

	/* Global styles for letters to be injected by JS */
	:global(.rosco-letter) {
		position: absolute;
		width: 36px;
		height: 36px;
		background-color: var(--circle-bg);
		border: 2px solid var(--circle-border);
		border-radius: 50%;
		display: flex;
		justify-content: center;
		align-items: center;
		font-weight: bold;
		font-size: 1.1rem;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		transition: all 0.3s;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
	}

	:global(.rosco-letter.active) {
		border-color: #fff;
		transform: translate(-50%, -50%) scale(1.3);
		z-index: 10;
		box-shadow: 0 0 15px var(--primary);
	}

	:global(.rosco-letter.correct) {
		background-color: var(--correct);
		border-color: var(--correct);
		color: white;
	}

	:global(.rosco-letter.incorrect) {
		background-color: var(--incorrect);
		border-color: var(--incorrect);
		color: white;
	}

	/* Game Controls inside the rosco */
	.game-controls {
		width: 100%;
		max-width: 400px;
		margin-top: 2rem;
		background: #1e293b;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
	}

	.current-letter {
		font-size: 3rem;
		font-weight: bold;
		color: var(--primary);
		margin-bottom: 0.5rem;
		text-transform: uppercase;
	}

	.definition {
		font-size: 1.2rem;
		line-height: 1.5;
		margin-bottom: 1.5rem;
		min-height: 80px;
	}

	#answer-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	#answer-input {
		padding: 0.75rem;
		font-size: 1.2rem;
		border: 2px solid #475569;
		border-radius: 8px;
		background-color: #0f172a;
		color: white;
		text-align: center;
	}

	#answer-input:focus {
		outline: none;
		border-color: var(--primary);
	}

	.actions {
		display: flex;
		gap: 0.5rem;
		justify-content: center;
	}

	.actions button {
		flex: 1;
	}

	.stats {
		font-size: 1.5rem;
		margin: 2rem 0;
	}

	.stats span {
		font-weight: bold;
	}
	#stat-correct { color: var(--correct); }
	#stat-incorrect { color: var(--incorrect); }

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 400px) {
		:root {
			--rosco-size: 280px;
		}
		:global(.rosco-letter) {
			width: 30px;
			height: 30px;
			font-size: 0.9rem;
		}
	}
</style>

<script>
	// --- Types & Interfaces ---
	interface WordItem {
		letter: string;
		word: string;
		definition: string;
		type?: "STARTS_WITH" | "INCLUDES";
		status: "unanswered" | "correct" | "incorrect" | "passed";
	}

	// --- State ---
	let words: WordItem[] = [];
	let currentIndex = 0;

	// --- DOM Elements ---
	const setupScreen = document.getElementById('setup-screen')!;
	const gameScreen = document.getElementById('game-screen')!;
	const resultsScreen = document.getElementById('results-screen')!;

	const btnGenerate = document.getElementById('btn-generate') as HTMLButtonElement;
	const loadingMsg = document.getElementById('loading-msg')!;
	const errorMsg = document.getElementById('error-msg')!;

	const roscoContainer = document.getElementById('rosco-container')!;
	const currentLetterDisplay = document.getElementById('current-letter-display')!;
	const definitionDisplay = document.getElementById('definition-display')!;
	const answerForm = document.getElementById('answer-form') as HTMLFormElement;
	const answerInput = document.getElementById('answer-input') as HTMLInputElement;
	const btnPasapalabra = document.getElementById('btn-pasapalabra')!;

	const statCorrect = document.getElementById('stat-correct')!;
	const statIncorrect = document.getElementById('stat-incorrect')!;
	const btnRestart = document.getElementById('btn-restart')!;

	// --- Functions ---

	// Normalize text to ignore accents and case
	function normalizeString(str: string): string {
		return str.trim().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
	}

	// Calculate circular positions for the letters
	function renderRosco() {
		roscoContainer.innerHTML = '';
		const totalLetters = words.length;
		const radius = roscoContainer.clientWidth / 2;

		words.forEach((item, index) => {
			// Start at the top (-90 degrees) and go clockwise
			const angle = (index / totalLetters) * 2 * Math.PI - (Math.PI / 2);
			const x = Math.cos(angle) * radius;
			const y = Math.sin(angle) * radius;

			const letterDiv = document.createElement('div');
			letterDiv.className = `rosco-letter ${item.status}`;
			letterDiv.id = `letter-${index}`;
			letterDiv.textContent = item.letter.toUpperCase();

			// Position the letter using margins based on the center
			letterDiv.style.marginTop = `${y}px`;
			letterDiv.style.marginLeft = `${x}px`;

			if (index === currentIndex && item.status !== 'correct' && item.status !== 'incorrect') {
				letterDiv.classList.add('active');
			}

			roscoContainer.appendChild(letterDiv);
		});
	}

	function updateGameUI() {
		// Update Rosco visual classes
		words.forEach((item, index) => {
			const el = document.getElementById(`letter-${index}`);
			if (el) {
				el.className = `rosco-letter ${item.status}`;
				if (index === currentIndex) {
					el.classList.add('active');
				}
			}
		});

		const currentItem = words[currentIndex];

		// Determine the prefix text
		const prefix = currentItem.type === 'INCLUDES' ? 'Contiene la' : 'Empieza por la';

		currentLetterDisplay.textContent = currentItem.letter.toUpperCase();
		definitionDisplay.innerHTML = `<strong>${prefix} ${currentItem.letter.toUpperCase()}:</strong> ${currentItem.definition}`;

		answerInput.value = '';
		answerInput.focus();
	}

	function findNextUnansweredIndex(): number {
		let nextIndex = (currentIndex + 1) % words.length;
		let loops = 0;

		// Find next unanswered or passed word
		while (
			(words[nextIndex].status === 'correct' || words[nextIndex].status === 'incorrect') &&
			loops < words.length
		) {
			nextIndex = (nextIndex + 1) % words.length;
			loops++;
		}

		if (loops >= words.length) return -1; // Game Over
		return nextIndex;
	}

	function checkGameOver() {
		const isGameOver = words.every(w => w.status === 'correct' || w.status === 'incorrect');

		if (isGameOver) {
			const correctCount = words.filter(w => w.status === 'correct').length;
			const incorrectCount = words.filter(w => w.status === 'incorrect').length;

			statCorrect.textContent = correctCount.toString();
			statIncorrect.textContent = incorrectCount.toString();

			gameScreen.classList.remove('active');
			gameScreen.classList.add('hidden');
			resultsScreen.classList.remove('hidden');
			resultsScreen.classList.add('active');
		} else {
			const nextIdx = findNextUnansweredIndex();
			if (nextIdx !== -1) {
				currentIndex = nextIdx;
				updateGameUI();
			}
		}
	}

	// --- Event Listeners ---

	btnGenerate.addEventListener('click', async () => {
		try {
			btnGenerate.disabled = true;
			loadingMsg.classList.remove('hidden');
			errorMsg.classList.add('hidden');

			const res = await fetch('/api/generate-rosco', {
				method: 'POST'
			});

			if (!res.ok) {
				const errorData = await res.json();
				throw new Error(errorData.error || 'Error en la petición');
			}

			const data = await res.json();

			if (!Array.isArray(data) || data.length === 0) {
				throw new Error('La IA no devolvió un formato válido.');
			}

			// Initialize state
			words = data.map(item => ({
				...item,
				status: 'unanswered'
			}));

			currentIndex = 0;

			setupScreen.classList.remove('active');
			setupScreen.classList.add('hidden');
			gameScreen.classList.remove('hidden');
			gameScreen.classList.add('active');

			renderRosco();
			updateGameUI();

		} catch (err: any) {
			console.error(err);
			errorMsg.textContent = `Error: ${err.message}. Revisa el log o tu API Key.`;
			errorMsg.classList.remove('hidden');
		} finally {
			btnGenerate.disabled = false;
			loadingMsg.classList.add('hidden');
		}
	});

	answerForm.addEventListener('submit', (e) => {
		e.preventDefault();
		const answer = answerInput.value;
		if (!answer) return;

		const currentItem = words[currentIndex];
		const isCorrect = normalizeString(answer) === normalizeString(currentItem.word);

		// For development/debug: you can log the correct word
		console.log(`Word was: ${currentItem.word}, Answered: ${answer}`);

		words[currentIndex].status = isCorrect ? 'correct' : 'incorrect';

		checkGameOver();
	});

	btnPasapalabra.addEventListener('click', () => {
		words[currentIndex].status = 'passed';
		checkGameOver();
	});

	btnRestart.addEventListener('click', () => {
		resultsScreen.classList.remove('active');
		resultsScreen.classList.add('hidden');
		setupScreen.classList.remove('hidden');
		setupScreen.classList.add('active');
		words = [];
	});

	// Handle window resize to recalculate circle positions
	window.addEventListener('resize', () => {
		if (gameScreen.classList.contains('active') && words.length > 0) {
			renderRosco();
			updateGameUI();
		}
	});

</script>
