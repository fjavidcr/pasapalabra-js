---
import Layout from '../layouts/Layout.astro';
import PasapalabraGame from '../components/PasapalabraGame.svelte';
import '../styles/global.css';
import CryptoJS from 'crypto-js';

// Implementación de seguridad HMAC
// Generamos un token en el servidor cuando se pide la página original
const timestamp = Math.floor(Date.now() / 1000).toString();
const secret = import.meta.env.API_SECRET_KEY;

if (!secret) {
	throw new Error("API_SECRET_KEY is missing in environment variables. Please check your .env file.");
}

const signature = CryptoJS.HmacSHA256(timestamp, secret).toString(CryptoJS.enc.Hex);
const secureToken = `${timestamp}.${signature}`;
---

<Layout>
	<main class="flex min-h-screen w-full flex-col items-center justify-center overflow-x-hidden">
		<PasapalabraGame client:load secureToken={secureToken} />
	</main>
</Layout>
