---
import Layout from '$layouts/Layout.astro';
import PasapalabraGame from '$components/PasapalabraGame.svelte';
import { generateRoscoWords } from '$lib/server/gemini';
import { generateSecureToken } from '$lib/server/security';
import type { RoscoGenerateItem } from '$lib/types';
import '$styles/global.css';

// Implementación de seguridad HMAC
let secureToken = '';
try {
	secureToken = generateSecureToken();
} catch (error) {
	console.error('Error generating secure token', error);
	// Handle error gracefully or throw if app cannot start
}

// Lógica SSR
let wordsPromise: Promise<RoscoGenerateItem[]> | null = null;
if (Astro.request.method === "POST") {
	const formData = Astro.request.formData();
	// Chain promise directly
	wordsPromise = formData.then(data => generateRoscoWords(data));
}
---

<Layout>
	<main class="flex min-h-screen w-full flex-col items-center justify-center overflow-x-hidden">
		{wordsPromise ? (
			wordsPromise
				.then(words => <PasapalabraGame client:load secureToken={secureToken} initialWords={words} />)
				.catch(err => <PasapalabraGame client:load secureToken={secureToken} errorMsg={err.message} />)
		) : (
			<PasapalabraGame client:load secureToken={secureToken} />
		)}
	</main>
</Layout>
