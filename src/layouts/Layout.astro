---
export interface Props {
	title?: string;
}

const { title = "Pasapalabra IA" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content="Generador de Rosco de Pasapalabra impulsado por Inteligencia Artificial. Juega a Pasapalabra de forma infinita con Gemini." />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Generador de Rosco de Pasapalabra impulsado por Inteligencia Artificial. Juega a Pasapalabra de forma infinita con Gemini." />
		<meta property="og:type" content="website" />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || Astro.url)} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	/* Any global reset or styles can go here */
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}
</style>