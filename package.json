{
  "name": "pasapalabra-js",
  "type": "module",
  "version": "0.7.0",
  "description": "El clásico juego del rosco en JavaScript",
  "author": "Javi del Castillo",
  "keywords": [
    "pasapalabra",
    "rosco",
    "juego",
    "javascript",
    "astro",
    "svelte"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fjavidcr/pasapalabra-js.git"
  },
  "bugs": {
    "url": "https://github.com/fjavidcr/pasapalabra-js/issues"
  },
  "license": "GPL-3.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "deploy:preview": "npm run build && wrangler deploy --env preview",
    "deploy:pro": "npm run build && wrangler deploy --env production",
    "astro": "astro",
    "test": "node --experimental-strip-types --test 'src/**/*.test.ts'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "check": "astro check",
    "postinstall": "lefthook install",
    "release": "release-it"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/svelte": "^7.2.5",
    "@google/genai": "^1.44.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.0",
    "crypto-js": "^4.2.0",
    "svelte": "^5.53.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@evilmartians/lefthook": "^2.1.3",
    "@lucide/svelte": "^0.577.0",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/crypto-js": "^4.2.2",
    "clsx": "^2.1.1",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-svelte": "^3.15.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "release-it": "^19.2.4",
    "svelte-eslint-parser": "^1.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^4.71.0"
  }
}
