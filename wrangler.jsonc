{
  "main": "dist/_worker.js/index.js",
  "name": "pasapalabra-js",
  "compatibility_date": "2026-03-09",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "workers_dev": false,
  "preview_urls": true,
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "env": {
    "preview": {
      "name": "pasapalabra-js-preview",
      "workers_dev": true
    }
  }
}
